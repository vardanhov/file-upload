<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">
    <changeSet author="user" id="1">
        <createTable tableName="white_list_user">
            <column autoIncrement="true" name="id" type="INT">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_name" type="varchar(255)"/>
            <column name="full_name" type="varchar(255)"/>
            <column name="group" type="varchar(255)"/>
            <column name="create_date" defaultValueNumeric="cast(extract(epoch from now())*1000 as bigint)" type="BIGINT"/>
            <column name="from" defaultValueNumeric="cast(extract(epoch from now())*1000 as bigint)" type="BIGINT"/>
            <column name="to" defaultValueNumeric="cast(extract(epoch from now())*1000 as bigint)" type="BIGINT"/>
            <column name="admin" type="INT"/>
        </createTable>
    </changeSet>
</databaseChangeLog>