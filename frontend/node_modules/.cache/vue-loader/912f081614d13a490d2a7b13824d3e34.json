n                <v-tooltip>\n                  <template v-slot:activator=\"{ on } \">\n                    <v-list-item-icon>\n                      <v-icon\n                          text round\n                          v-text=\"link.icon\"\n                      ></v-icon>\n                    </v-list-item-icon>\n                    <v-list-item-content>\n                      <v-list-item-title\n                          v-text=\"link.label\"\n                      >\n                      </v-list-item-title>\n                    </v-list-item-content>\n                  </template>\n                  <span v-text=\"link.label\"></span>\n                </v-tooltip>\n              </v-list-item>\n            </v-list-item-group>\n          </v-list>\n          <form method=\"post\" action=\"/logout\" style=\"width: 100%; background-color: #fff\">\n            <v-btn type=\"submit\" text>\n              <v-icon color=\"grey\">mdi-logout</v-icon>\n              <span style=\"color: gray; margin-left: 33px\"></span> Выйти\n            </v-btn>\n          </form>\n        </v-menu>\n      </div>\n    </v-app-bar>\n  </v-card>\n</template>\n\n<script>\nimport axios from \"axios\";\n\nexport default {\n  data: () => ({\n    drawer: false,\n    group: null,\n    links: [\n      {\n        name: 'На главную',\n        label: 'На главную',\n        url: '/home',\n        icon: 'mdi-home-outline',\n      },\n      {\n        label: 'Отправить файл',\n        url: '/upload',\n        icon: 'mdi-paperclip',\n      },\n      {\n        label: 'Панель управления',\n        url: '/admin',\n        icon: 'mdi-account-group',\n      }\n    ]\n\n  }),\n\n}\n</script>\n"]}]}