{"remainingRequest":"/home/jonjua_rm/github/file-upload/frontend/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/jonjua_rm/github/file-upload/frontend/src/components/Admin.vue?vue&type=script&lang=js&","dependencies":[{"path":"/home/jonjua_rm/github/file-upload/frontend/src/components/Admin.vue","mtime":1614268035676},{"path":"/home/jonjua_rm/github/file-upload/frontend/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/jonjua_rm/github/file-upload/frontend/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Admin.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAyIA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Admin.vue","sourceRoot":"src/components","sourcesContent":["<template>\n  <div>\n    <v-col md=\"4\" offset=\"8\">\n      <v-text-field\n          v-model=\"search\"\n          append-icon=\"mdi-magnify\"\n          label=\"Поиск пользователей\"\n          single-line\n          hide-details\n      ></v-text-field>\n    </v-col>\n    <v-data-table\n        :headers=\"headers\"\n        :items=\"getUsers\"\n        :items-per-page=\"10\"\n        class=\"elevation-1\"\n        :search=\"search\"\n    >\n      <template v-slot:item.edit=\"{ item }\">\n        <v-dialog v-model=\"dialogs[item.id]\" persistent max-width=\"800\">\n          <template v-slot:activator=\"{ on }\">\n            <v-btn text class=\"modal-btn\" v-model=\"item.edit\" color=\"primary\" v-on=\"on\">\n              <v-icon color=\"secondary\">mdi-pencil</v-icon>\n            </v-btn>\n          </template>\n          <v-card>\n            <v-container>\n              <v-row>\n                <v-card-title class=\"headline\" style=\"color: gray\">Настройка времени для {{ item.username }}\n                </v-card-title>\n                <v-spacer></v-spacer>\n                <v-btn text @click.stop=\"$set(dialogs, item.id, false)\">\n                  <v-icon color=\"red\">mdi-window-close</v-icon>\n                </v-btn>\n              </v-row>\n            </v-container>\n            <v-card-text>\n              <v-container>\n                <div>Сервис доступен С:</div>\n                <br/>\n                <v-row>\n                  <v-date-picker\n                      v-model=\"datePickerFrom[item.id]\"\n                  ></v-date-picker>\n                  &nbsp;\n                  &nbsp;\n                  &nbsp;\n                  <v-time-picker\n                      v-model=\"timePickerFrom[item.id]\"\n                  ></v-time-picker>\n                </v-row>\n                <br/>\n                <div>Сервис доступен ПО:</div>\n                <br/>\n                <v-row>\n                  <v-date-picker\n                      v-model=\"datePickerTo[item.id]\"\n                  ></v-date-picker>\n                  &nbsp;\n                  &nbsp;\n                  &nbsp;\n                  <v-time-picker\n                      v-model=\"timePickerTo[item.id]\"\n                  ></v-time-picker>\n                </v-row>\n              </v-container>\n\n            </v-card-text>\n            <v-spacer></v-spacer>\n            <v-card-actions>\n              <v-spacer></v-spacer>\n              <v-btn text color=\"green\" @click=\"save(item.id)\">\n                Сохранить\n              </v-btn>\n            </v-card-actions>\n          </v-card>\n        </v-dialog>\n      </template>\n      <template v-slot:item.delete=\"{ item }\">\n        <v-btn v-model=\"item.delete\" text color=\"red\">\n          <v-icon @click=\"disable(item.id)\">mdi-window-close</v-icon>\n        </v-btn>\n      </template>\n      <template v-slot:item.upload=\"{ item }\">\n        <v-card-text>{{ item.upload }}\n          <v-icon v-model=\"item.upload\" v-if=\"item.upload\" color=\"green\">mdi-circle-medium</v-icon>\n          <v-icon v-model=\"item.upload\" v-else color=\"red\">mdi-circle-medium</v-icon>\n        </v-card-text>\n      </template>\n      <template v-slot:item.сhecked=\"{ item }\">\n        <v-simple-checkbox\n            v-model=\"checkboxes[item.id]\"\n        ></v-simple-checkbox>\n      </template>\n    </v-data-table>\n    <br/>\n\n    <v-col></v-col>\n    <v-col>\n      <v-row>\n        <v-spacer></v-spacer>\n        <v-text-field v-model=\"user\"\n                      label=\"Введите логин пользователя из AD\"\n        ></v-text-field>\n        <v-btn text color=\"accent4\" @click=\"addUser()\">\n          Добавить\n        </v-btn>\n      </v-row>\n    </v-col>\n\n    <template>\n      <div class=\"text-center ma-2\">\n        <v-snackbar\n            v-model=\"snackbar\"\n            @mousemove=\"snackbarText=false\"\n        >\n          {{ snackbarText }}\n\n          <template v-slot:action=\"{ attrs }\">\n            <v-btn\n                color=\"pink\"\n                text\n                v-bind=\"attrs\"\n                @click=\"snackbar = false\"\n            >\n              <v-icon>mdi-cancel</v-icon>\n            </v-btn>\n          </template>\n        </v-snackbar>\n      </div>\n    </template>\n  </div>\n\n\n</template>\n\n<script>\nimport {mapGetters} from \"vuex\";\nimport axios from \"axios\";\n\nexport default {\n  name: \"Admin\",\n\n  computed: mapGetters(['getUsers']),\n  data: () => ({\n    headers: [\n      {text: 'id', value: 'id'},\n      {text: 'логин', value: 'username'},\n      {text: 'дата создания', value: 'createDate'},\n      {text: 'дата обновления', value: 'trigger'},\n      {text: 'права на загрузку', value: 'upload'},\n      {text: 'админ', value: 'admin'},\n      {text: \"редактировать\", value: \"edit\"},\n      {text: 'задизейблить', value: \"delete\"},\n      {text: 'выбрать', value: \"сhecked\"},\n\n    ],\n    dialogs: {},\n    dialog: false,\n    datePickerFrom: {},\n    timePickerFrom: {},\n    datePickerTo: {},\n    timePickerTo: {},\n    checkboxes: {},\n    user: '',\n    snackbar:false,\n    search: '',\n    snackbarText:'',\n  }),\n\n  created() {\n    this.$store.dispatch(\"fetchUsers\")\n  },\n  methods: {\n    disable(id) {\n      axios.post('/api/users/limit-access/' + id).then(function () {\n        console.log('SUCCESS!!');\n      }).catch(function () {\n        console.log('FAILURE!!');\n      });\n    },\n    save(id) {\n      var self = this;\n      axios.post('/api/users/grant-access/' + id, {\n        dateTimeFrom: self.datePickerFrom[id] + \" \" + self.timePickerFrom[id],\n        dateTimeTo: self.datePickerTo[id] + \" \" + self.timePickerTo[id],\n      }).then(function () {\n        console.log('SUCCESS!!');\n      }).catch(function () {\n        console.log('FAILURE!!');\n      }).then(function () {\n        self.dialogs[id] = false;\n      });\n    },\n    addUser() {\n      var self = this;\n      axios.post('/api/whitelist/add-by-username', self.user,  {headers: {\"Content-Type\": \"text/plain\"}})\n          .catch(function (error) {\n        self.handleEditError(error.response.data)\n      }).then(function () {\n        self.user = '';\n      });\n    },\n    handleEditError(response){\n      this.snackbar=true;\n      this.snackbarText=response;\n    }\n  }\n}\n</script>\n\n<style>\n\n</style>"]}]}